# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Base URL for OAuth redirects (no trailing slash)
# In dev, use port 5173 (Vite proxies /api to the backend)
OAUTH_REDIRECT_BASE=http://localhost:5173

# Database path
DB_PATH=data/accal.db

# Server port
PORT=3000

# Environment
NODE_ENV=development

# SMTP (for magic link emails)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=accal <noreply@localhost>

# Proxy (set to true if behind a reverse proxy like nginx)
TRUST_PROXY=false

# WebAuthn / Passkeys
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=accal
WEBAUTHN_ORIGIN=http://localhost:5173
